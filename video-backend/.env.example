# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
BACKEND_SECRET=your-random-secret-here  # Must match BACKEND_SECRET in Next.js

# ── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stock Footage APIs ────────────────────────────────────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── Voice APIs ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=

# ── Replicate (Hailuo AI fallback - Phase 3) ─────────────────────────────────
REPLICATE_API_TOKEN=

# ── Firebase Admin ────────────────────────────────────────────────────────────
# Paste the entire service account JSON as a single line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"Thinksuite",...}
FIREBASE_STORAGE_BUCKET=Thinksuite.firebasestorage.app
