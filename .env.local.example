# ================================================================
# ThinkSuite AI Intelligence Engine — Environment Variables
# Copy to .env.local and fill in your values
# ================================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://thinksuite.in

# --- Firebase Admin SDK (Server) ---
# Firebase Console > Project Settings > Service Accounts > Generate Private Key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# --- Firebase Client SDK (Browser) ---
# Firebase Console > Project Settings > General > Your apps > Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- AI APIs ---
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIzaSy...
GROQ_API_KEY=gsk_...
# Z.ai (Zhipu AI) — GLM-5.2, used as a fallback provider in lib/llm.ts
# console.z.ai > API Keys
ZAI_API_KEY=...

# --- GitHub (Optional — higher rate limits) ---
# github.com/settings/tokens > New classic token > No scopes needed
GITHUB_TOKEN=ghp_...

# --- Telegram Bot ---
# 1. Message @BotFather on Telegram, /newbot
# 2. Get your bot token
# 3. Create a channel, add bot as admin
# 4. CHANNEL_ID = @yourchannel or numeric ID
TELEGRAM_BOT_TOKEN=1234567890:AAF...
TELEGRAM_CHANNEL_ID=@thinksuite_ai

# --- LinkedIn (Optional) ---
# developer.linkedin.com > Create App > OAuth 2.0 > r_organization_social + w_organization_social
LINKEDIN_ACCESS_TOKEN=AQX...
LINKEDIN_ORG_ID=12345678

# --- WhatsApp Business (Optional) ---
# developers.facebook.com > WhatsApp > Getting Started
WHATSAPP_TOKEN=EAAJ...
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_GROUP_ID=+1234567890

# --- Discord (Optional) ---
# Channel Settings > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Slack (Optional) ---
# api.slack.com/apps > Incoming Webhooks > Add to Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Cron Security ---
# Random secret to protect /api/cron/fetch-news
# Generate: openssl rand -base64 32
CRON_SECRET=your-random-secret-here
