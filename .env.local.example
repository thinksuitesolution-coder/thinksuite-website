# ================================================================
# ThinkSuite AI Intelligence Engine — Environment Variables
# Copy to .env.local and fill in your values
# ================================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://thinksuite.in

# --- Stripe (international payments, alongside Razorpay for India) ---
# dashboard.stripe.com > Developers > API keys
STRIPE_SECRET_KEY=sk_live_...
# dashboard.stripe.com > Developers > Webhooks > Add endpoint
# Endpoint URL: https://thinksuite.in/api/stripe/webhook
# Events to send: checkout.session.completed, customer.subscription.deleted, invoice.payment_failed
# Copy the "Signing secret" shown after creating the endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# IMPORTANT: also enable Stripe Tax (dashboard.stripe.com > Settings > Tax > Enable automatic tax)
# and add your business's origin address there, so Stripe auto-calculates and collects
# VAT/GST/sales tax per customer country instead of you having to register everywhere yourself.

# --- Search engine verification (international SEO) ---
# Google Search Console > Add Property > HTML tag method > copy content= value only
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools > can import directly from Google Search Console (recommended,
# no code needed) OR Add Site > HTML meta tag method > copy content= value only
BING_SITE_VERIFICATION=
# Yandex Webmaster (optional, useful for Russia/CIS/some EU traffic) > Add Site > Meta tag
YANDEX_SITE_VERIFICATION=

# --- Firebase Admin SDK (Server) ---
# Main platform project — auth, leads, subscriptions, wallets, etc.
# (lib/firebaseAdmin.js). Do NOT change these to the news project.
# Firebase Console > Project Settings > Service Accounts > Generate Private Key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# --- Firebase Client SDK (Browser) ---
# Firebase Console > Project Settings > General > Your apps > Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- AI News Firebase project (SEPARATE, free Spark plan) ---
# Its own Firebase project, used only by lib/firebase-admin.ts for the
# ai_articles / ai_raw_events / ai_processed_urls collections. Isolated from
# the main project above so the news pipeline can never affect auth/billing.
# Firebase Console (new project) > Project Settings > Service Accounts > Generate Private Key
NEWS_FIREBASE_PROJECT_ID=your-news-project-id
NEWS_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-news-project.iam.gserviceaccount.com
NEWS_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# --- AI APIs ---
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIzaSy...
GROQ_API_KEY=gsk_...
# Z.ai (Zhipu AI) — GLM-5.2, used as a fallback provider in lib/llm.ts
# console.z.ai > API Keys
ZAI_API_KEY=...

# --- GitHub (Optional — higher rate limits) ---
# github.com/settings/tokens > New classic token > No scopes needed
GITHUB_TOKEN=ghp_...

# --- Telegram Bot ---
# 1. Message @BotFather on Telegram, /newbot
# 2. Get your bot token
# 3. Create a channel, add bot as admin
# 4. CHANNEL_ID = @yourchannel or numeric ID
TELEGRAM_BOT_TOKEN=1234567890:AAF...
TELEGRAM_CHANNEL_ID=@thinksuite_ai

# --- LinkedIn (Optional) ---
# developer.linkedin.com > Create App > OAuth 2.0 > r_organization_social + w_organization_social
LINKEDIN_ACCESS_TOKEN=AQX...
LINKEDIN_ORG_ID=12345678

# --- WhatsApp Business (Optional) ---
# developers.facebook.com > WhatsApp > Getting Started
WHATSAPP_TOKEN=EAAJ...
WHATSAPP_PHONE_ID=1234567890
WHATSAPP_GROUP_ID=+1234567890

# --- Discord (Optional) ---
# Channel Settings > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Slack (Optional) ---
# api.slack.com/apps > Incoming Webhooks > Add to Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Email (SMTP) — powers delete-account emails and the AI Pulse newsletter cron ---
# Any SMTP provider works (Gmail App Password, Zoho, SES SMTP, etc.)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=info@thinksuite.in
EMAIL_SERVER_PASSWORD=your-smtp-password-or-app-password
EMAIL_FROM=ThinkSuite AI Pulse <info@thinksuite.in>

# --- Cron Security ---
# Random secret to protect /api/cron/fetch-news
# Generate: openssl rand -base64 32
CRON_SECRET=your-random-secret-here

# --- Turso (AI News archive: articles older than 14 days, up to 3 months) ---
# turso.tech > sign up (free) > create database > `turso db show <name> --url` and
# `turso auth token create` (or copy both from the dashboard)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJ...
