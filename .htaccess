Options -Indexes
DirectoryIndex home.html

RewriteEngine On

# home.html → / (homepage clean URL)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s/+home\.html[\s?] [NC]
RewriteRule ^ / [R=301,L]

# Redirect page.html → page (clean URLs for all other pages)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internally serve .html file when clean URL is requested
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^ %{REQUEST_URI}.html [L]
